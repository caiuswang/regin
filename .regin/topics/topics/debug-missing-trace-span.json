  "blurb": "A session shows fewer spans than its transcript holds \u2014 triage the hooks log, ingest-errors, and seen-uuid cache, then run the repair.",
  "commands": [
    ".venv/bin/python cli/regin.py logs tail --feature hooks -n 200",
    ".venv/bin/python cli/regin.py logs grep 'handler_failed|handler_slow' --feature hooks",
    ".venv/bin/python cli/regin.py logs grep span_repair_completed --feature trace_ingest",
    "tail -n 200 ~/.claude/traces/ingest-errors.jsonl",
    "curl -s 'http://127.0.0.1:8321/api/ingest-errors?limit=100' -H \"Authorization: Bearer $TOKEN\"",
    "find ~/.claude/projects -name '<trace_id>.jsonl' -print -quit",
    "wc -l ~/.local/share/regin/turn_trace_state/<trace_id>.txt",
    "sqlite3 ~/.local/share/regin/regin.db \"SELECT name, count(*) FROM session_spans WHERE trace_id='<trace_id>' GROUP BY name ORDER BY name\"",
    "lsof -i :8321",
    ".venv/bin/python -c \"from lib.trace.repair import repair_session_spans; import json; print(json.dumps(repair_session_spans('<trace_id>'), indent=2))\"",
    "curl -X POST -H \"Authorization: Bearer $TOKEN\" http://127.0.0.1:8321/api/sessions/<trace_id>/repair-spans",
    "curl -X POST -H \"Authorization: Bearer $TOKEN\" http://127.0.0.1:8321/api/sessions/<trace_id>/materialize"
  ],
