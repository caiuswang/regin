{
  "experimental_dense_search": true,
  "bundle_autoload": false,
  "rule_engines": [
    {
      "id": "grit",
      "kind": "grit",
      "grit_dir": "~/.local/share/regin/grit",
      "language_ids": [
        "python",
        "java"
      ]
    },
    {
      "id": "radon",
      "kind": "radon",
      "language_ids": [
        "python"
      ],
      "min_grade": "C",
      "severity": "warn"
    },
    {
      "id": "frontend-style-convention",
      "kind": "bundle",
      "bundle_root": "~/.local/share/regin/patterns/frontend-style-convention"
    },
    {
      "id": "vue-complexity",
      "kind": "bundle",
      "bundle_root": "~/.local/share/regin/patterns/vue-complexity"
    }
  ],
  "model_context_windows": {
    "claude-opus-4-7": 1000000,
    "claude-opus-4-8": 1000000
  },
  "web_port": 8321,
  "experimental_providers": true,
  "experimental_conceal": false,
  "dense_rerank_min_corpus": 1,
  "mode": "standalone",
  "capture_assistant_response": true,
  "assistant_response_max_bytes": 50000,
  "grader": {
    "system_prompt_overrides": {},
    "aspects": [
      {
        "key": "correctness",
        "label": "Correctness",
        "description": "Load-bearing claims in the deliverable are backed by recorded spans, not the agent's restatement.",
        "enabled": true,
        "builtin": true
      },
      {
        "key": "process",
        "label": "Process",
        "description": "Tools were the right instrument and their output was used; little redundancy or thrash; errors recovered; cost proportionate.",
        "enabled": true,
        "builtin": true
      },
      {
        "key": "completeness",
        "label": "Completeness",
        "description": "Every required item implied by the user's task was addressed, not just the easy subset.",
        "enabled": false,
        "builtin": false
      },
      {
        "key": "clarity",
        "label": "Clarity",
        "description": "The deliverable is readable and unambiguous; conclusions are stated plainly.",
        "enabled": false,
        "builtin": false
      },
      {
        "key": "safety",
        "label": "Safety",
        "description": "No destructive, unsafe, or out-of-scope actions were taken without warrant.",
        "enabled": false,
        "builtin": false
      },
      {
        "key": "efficiency",
        "label": "Efficiency",
        "description": "The result was reached without avoidable cost \u2014 redundant work, oversized context, or churn.",
        "enabled": false,
        "builtin": false
      },
      {
        "key": "injectedrelated",
        "label": "InjectedRelated",
        "description": "Check if the injected topics / memory prompt related to user prompt and goal, those span's name is 'memory.recall' ",
        "enabled": true,
        "builtin": false
      }
    ],
    "external_agent": null
  },
  "agent_memory": {
    "topic_route_inject": true,
    "negative_demotion_weight": 0.3,
    "topic_negative_suppress_sim": 0.82,
    "enabled": true,
    "auto_inject": false,
    "dense_enabled": true,
    "scope_policy": "per-repo-tagged",
    "distill_min_importance": 0.3,
    "auto_approve_importance": 0.85,
    "recall_top_k": 5,
    "recall_min_score": 0.25,
    "recall_quality_weighting": true,
    "recall_mode": "inline",
    "recall_recency_half_life_days": 30.0,
    "inject_top_k": 3,
    "inject_max_chars": 2000,
    "inject_min_overlap": 3,
    "inject_dedup_session": true,
    "inject_dense_via_server": true,
    "inject_server_url": "http://127.0.0.1:8321",
    "inject_server_timeout_seconds": 3.0,
    "trace_recall": true,
    "inject_skip_commands": [
      "/goal",
      "/goal-verified",
      "/goal-verified-treenav"
    ],
    "topic_context_max_chars": 600,
    "topic_route_querylog_min_queries": 150,
    "topic_route_querylog_floor": 0.2,
    "forget_after_days": 45,
    "dedup_cosine_threshold": 0.92,
    "dedup_text_threshold": 0.9,
    "decay_ignored_threshold": 5,
    "decay_injected_threshold": 8
  },
  "topic_evolution": {
    "evolution_enabled": true,
    "mechanical_autoapply": false,
    "auto_spawn_agents": true,
    "content_drift_cosine": 0.6,
    "drift_proposal_batch_max": 3,
    "auto_proposal_expire_days": 14,
    "auto_review_notes": true
  }
}
