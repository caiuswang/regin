{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bash PostToolUse payload",
  "type": "object",
  "required": [
    "tool_name",
    "tool_input"
  ],
  "additionalProperties": true,
  "properties": {
    "tool_name": {
      "const": "Bash"
    },
    "tool_input": {
      "type": "object",
      "required": [
        "command"
      ],
      "additionalProperties": true,
      "properties": {
        "command": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "timeout": {
          "type": "integer"
        },
        "run_in_background": {
          "type": "boolean"
        }
      }
    },
    "tool_response": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "interrupted": {
          "type": "boolean"
        },
        "is_image": {
          "type": "boolean"
        },
        "no_output_expected": {
          "type": "boolean"
        }
      }
    },
    "duration_ms": {
      "type": "integer"
    },
    "effort": {
      "type": "object"
    }
  },
  "x-claude-versions": [
    "2.1.150"
  ]
}
