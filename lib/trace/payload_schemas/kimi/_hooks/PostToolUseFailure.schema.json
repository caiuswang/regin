{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PostToolUseFailure hook payload (Kimi)",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "agent_type": {
      "type": "string"
    },
    "tool_name": {
      "type": "string"
    },
    "tool_input": {
      "type": "object"
    },
    "tool_use_id": {
      "type": "string"
    },
    "error": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    }
  },
  "required": []
}
