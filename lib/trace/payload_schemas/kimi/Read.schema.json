{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Read PostToolUse payload (Kimi)",
  "type": "object",
  "required": [
    "tool_name",
    "tool_input"
  ],
  "additionalProperties": true,
  "properties": {
    "tool_name": {
      "const": "Read"
    },
    "tool_input": {
      "type": "object",
      "required": [
        "path"
      ],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string"
        },
        "line_offset": {
          "type": "integer"
        },
        "n_lines": {
          "type": "integer"
        },
        "offset": {
          "type": "integer"
        },
        "limit": {
          "type": "integer"
        }
      }
    },
    "tool_response": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
