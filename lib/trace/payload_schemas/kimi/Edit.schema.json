{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Edit PostToolUse payload (Kimi)",
  "type": "object",
  "required": [
    "tool_name",
    "tool_input"
  ],
  "additionalProperties": true,
  "properties": {
    "tool_name": {
      "const": "Edit"
    },
    "tool_input": {
      "type": "object",
      "required": [
        "path",
        "old_string",
        "new_string"
      ],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string"
        },
        "old_string": {
          "type": "string"
        },
        "new_string": {
          "type": "string"
        },
        "replace_all": {
          "type": "boolean"
        }
      }
    },
    "tool_response": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
