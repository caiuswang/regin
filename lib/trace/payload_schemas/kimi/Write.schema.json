{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Write PostToolUse payload (Kimi)",
  "type": "object",
  "required": [
    "tool_name",
    "tool_input"
  ],
  "additionalProperties": true,
  "properties": {
    "tool_name": {
      "const": "Write"
    },
    "tool_input": {
      "type": "object",
      "required": [
        "path",
        "content"
      ],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string"
        },
        "content": {
          "type": "string"
        }
      }
    },
    "tool_response": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
